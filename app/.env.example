# OwenFlow app env vars. Copy to `app/.env` and edit values to take effect.
# Loaded at startup by app/src/main/dotenv.ts.
# Shell-set vars always win, so you can also `export OWENFLOW_PORT=...` ad-hoc.
#
# Note: API keys (Groq, MiniMax, ZEAL) do NOT live here — they go in
# Settings UI (persisted by electron-store). This file is only for runtime
# overrides of how the app and sidecar are wired together.

# ─── App → sidecar wiring ────────────────────────────────────────────────────

# Override the Python interpreter used to spawn the STT sidecar.
# Auto-detection order if unset:
#   1. <repo>/sidecar/.venv/bin/python (or .venv\Scripts\python.exe on Windows)
#   2. `python3` (Windows: `py -3.13`)
# Set this if your venv lives elsewhere, or you want to use a system Python.
# OWENFLOW_PYTHON=/opt/homebrew/bin/python3.13

# Sidecar HTTP port. Default: 8484.
# OWENFLOW_PORT=8484

# Escape hatch: force the sidecar directory to an absolute path.
# Default: auto-resolved as <app>/../sidecar (dev) or resources/sidecar (packaged).
# OWENFLOW_SIDECAR_DIR=/abs/path/to/sidecar

# ─── Sidecar-side (flow through via spawn env) ───────────────────────────────
# These are read by sidecar/server.py. Because the Electron app passes
# process.env to `spawn`, anything you set here also reaches the sidecar.

# Whisper model. tiny | base | small | medium | large-v3 | large-v3-turbo
# In normal operation the app overrides this from Settings (default: small),
# so this env var only matters if you want to FORCE a model regardless of
# what's saved in the UI.
# OWENFLOW_MODEL=small

# ctranslate2 compute type. Override the auto-pick.
# CPU options: int8 | int8_float32 | float32
# CUDA options: int8_float16 | float16 | float32
# OWENFLOW_COMPUTE=int8
