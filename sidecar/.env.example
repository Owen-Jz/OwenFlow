# Sidecar env vars. ONLY read when running the sidecar standalone
# (`python server.py`, e.g. for `test_sidecar.py` or curl debugging).
#
# When the Electron app launches the sidecar, it supplies these directly
# via spawn env — use app/.env to control that path instead. python server.py
# does NOT load this file automatically; either `export` the vars first
# or rely on the app to inject them.

# Whisper model size. tiny | base | small | medium | large-v3 | large-v3-turbo
# Default in code: large-v3-turbo (CUDA assumption). Use `small` for CPU/Mac.
# OWENFLOW_MODEL=small

# Sidecar HTTP port. Default: 8484.
# OWENFLOW_PORT=8484

# ctranslate2 compute type. Override the auto-pick.
# CPU options: int8 | int8_float32 | float32
# CUDA options: int8_float16 | float16 | float32
# OWENFLOW_COMPUTE=int8
